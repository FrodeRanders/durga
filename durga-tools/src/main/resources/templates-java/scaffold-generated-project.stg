processEventsWatcherClass(packageName, className, processId, eventsTopic) ::= <<
package %packageName%;

import org.apache.kafka.clients.consumer.ConsumerConfig;
import org.apache.kafka.clients.consumer.ConsumerRecord;
import org.apache.kafka.clients.consumer.ConsumerRecords;
import org.apache.kafka.clients.consumer.KafkaConsumer;
import org.apache.kafka.common.serialization.StringDeserializer;
import org.gautelis.durga.ProcessEvent;

import java.time.Duration;
import java.util.Collections;
import java.util.Properties;
import java.util.UUID;

public class %className% {
    public static void main(String[] args) {
        String bootstrap = args.length > 0 ? args[0] : "localhost:9094";
        String processInstanceId = args.length > 1 ? args[1] : "";
        int maxRecords = args.length > 2 ? Integer.parseInt(args[2]) : 20;
        long timeoutSeconds = args.length > 3 ? Long.parseLong(args[3]) : 30;

        Properties props = new Properties();
        props.put(ConsumerConfig.BOOTSTRAP_SERVERS_CONFIG, bootstrap);
        props.put(ConsumerConfig.GROUP_ID_CONFIG, "%processId%-process-events-watcher-" + UUID.randomUUID());
        props.put(ConsumerConfig.KEY_DESERIALIZER_CLASS_CONFIG, StringDeserializer.class.getName());
        props.put(ConsumerConfig.VALUE_DESERIALIZER_CLASS_CONFIG, StringDeserializer.class.getName());
        props.put(ConsumerConfig.AUTO_OFFSET_RESET_CONFIG, "earliest");

        try (KafkaConsumer<String, String> consumer = new KafkaConsumer<>(props)) {
            consumer.subscribe(Collections.singletonList("%eventsTopic%"));
            long deadlineMs = System.currentTimeMillis() + (timeoutSeconds * 1000);
            int seen = 0;

            while (System.currentTimeMillis() < deadlineMs && seen < maxRecords) {
                ConsumerRecords<String, String> records = consumer.poll(Duration.ofSeconds(1));
                for (ConsumerRecord<String, String> record : records) {
                    ProcessEvent event = ProcessEvent.fromJson(record.value());
                    if (!"%processId%".equals(event.processId())) {
                        continue;
                    }
                    if (!processInstanceId.isBlank() && !processInstanceId.equals(event.processInstanceId())) {
                        continue;
                    }
                    seen++;
                    System.out.println(
                            seen
                                    + " " + event.timestamp()
                                    + " instance=" + event.processInstanceId()
                                    + " activity=" + event.activityId()
                                    + " status=" + event.status()
                                    + " event=" + event.eventType()
                                    + " payload=" + event.payload()
                    );
                    if (seen >= maxRecords) {
                        break;
                    }
                }
            }

            System.out.println("Watcher finished after records=" + seen);
        }
    }
}
>>

