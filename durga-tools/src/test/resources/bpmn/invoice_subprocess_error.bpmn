<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://example.com/bpmn">
  <error id="review_scope_error_def" name="Review Scope Error" errorCode="approve_invoice_failed" />
  <process id="invoice_subprocess_error" name="Invoice Subprocess Error" isExecutable="true">
    <startEvent id="start" name="Invoice Received" />
    <sequenceFlow id="flow_start_to_register" sourceRef="start" targetRef="register_invoice" />
    <serviceTask id="register_invoice" name="Register Invoice" />
    <sequenceFlow id="flow_register_to_review_scope" sourceRef="register_invoice" targetRef="review_scope" />
    <subProcess id="review_scope" name="Review Scope">
      <startEvent id="review_scope_start" name="Enter Review" />
      <sequenceFlow id="flow_scope_start_to_review" sourceRef="review_scope_start" targetRef="review_invoice" />
      <userTask id="review_invoice" name="Review Invoice" />
      <sequenceFlow id="flow_review_to_approve" sourceRef="review_invoice" targetRef="approve_invoice" />
      <serviceTask id="approve_invoice" name="Approve Invoice" />
      <sequenceFlow id="flow_approve_to_scope_end" sourceRef="approve_invoice" targetRef="review_scope_end" />
      <endEvent id="review_scope_end" name="Review Done" />
    </subProcess>
    <boundaryEvent id="review_scope_error" name="Review Scope Error" attachedToRef="review_scope">
      <errorEventDefinition errorRef="review_scope_error_def" />
    </boundaryEvent>
    <sequenceFlow id="flow_error_to_reject" sourceRef="review_scope_error" targetRef="reject_invoice" />
    <sequenceFlow id="flow_scope_to_notify" sourceRef="review_scope" targetRef="notify_requester" />
    <serviceTask id="notify_requester" name="Notify Requester" />
    <sequenceFlow id="flow_notify_to_end" sourceRef="notify_requester" targetRef="end_completed" />
    <serviceTask id="reject_invoice" name="Reject Invoice" />
    <sequenceFlow id="flow_reject_to_end" sourceRef="reject_invoice" targetRef="end_failed" />
    <endEvent id="end_completed" name="Invoice Reviewed" />
    <endEvent id="end_failed" name="Invoice Rejected" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_invoice_subprocess_error">
    <bpmndi:BPMNPlane id="BPMNPlane_invoice_subprocess_error" bpmnElement="invoice_subprocess_error">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <omgdc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="register_invoice_di" bpmnElement="register_invoice">
        <omgdc:Bounds x="25" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_scope_di" bpmnElement="review_scope">
        <omgdc:Bounds x="25" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_scope_error_di" bpmnElement="review_scope_error">
        <omgdc:Bounds x="57" y="372" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="notify_requester_di" bpmnElement="notify_requester">
        <omgdc:Bounds x="25" y="450" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="reject_invoice_di" bpmnElement="reject_invoice">
        <omgdc:Bounds x="25" y="590" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_completed_di" bpmnElement="end_completed">
        <omgdc:Bounds x="57" y="752" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_failed_di" bpmnElement="end_failed">
        <omgdc:Bounds x="57" y="892" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_scope_start_di" bpmnElement="review_scope_start">
        <omgdc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_invoice_di" bpmnElement="review_invoice">
        <omgdc:Bounds x="25" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="approve_invoice_di" bpmnElement="approve_invoice">
        <omgdc:Bounds x="25" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_scope_end_di" bpmnElement="review_scope_end">
        <omgdc:Bounds x="57" y="472" width="36" height="36" />
      </bpmndi:BPMNShape>
    <bpmndi:BPMNEdge id="flow_start_to_register_di" bpmnElement="flow_start_to_register"><omgdi:waypoint x="75" y="88" /><omgdi:waypoint x="75" y="170" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_register_to_review_scope_di" bpmnElement="flow_register_to_review_scope"><omgdi:waypoint x="75" y="250" /><omgdi:waypoint x="75" y="310" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_error_to_reject_di" bpmnElement="flow_error_to_reject"><omgdi:waypoint x="75" y="408" /><omgdi:waypoint x="75" y="590" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_scope_to_notify_di" bpmnElement="flow_scope_to_notify"><omgdi:waypoint x="75" y="390" /><omgdi:waypoint x="75" y="450" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_notify_to_end_di" bpmnElement="flow_notify_to_end"><omgdi:waypoint x="75" y="530" /><omgdi:waypoint x="75" y="752" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_reject_to_end_di" bpmnElement="flow_reject_to_end"><omgdi:waypoint x="75" y="670" /><omgdi:waypoint x="75" y="892" /></bpmndi:BPMNEdge></bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>