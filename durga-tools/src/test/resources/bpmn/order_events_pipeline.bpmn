<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="order_events_pipeline" name="Order Events Pipeline" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Ingest from source">
      <bpmn:outgoing>Flow_to_normalize</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="normalize_order" name="Normalize Order">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="plugin" value="json-transform" />
          <camunda:property name="pluginConfig" value="id:order_id, customer.name, customer.email, items, total:amount, status, created_at:timestamp" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_normalize</bpmn:incoming>
      <bpmn:outgoing>Flow_normalize_to_coerce</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="coerce_types" name="Coerce Types">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="plugin" value="type-coercer" />
          <camunda:property name="pluginConfig" value="amount:double, order_id:int" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_normalize_to_coerce</bpmn:incoming>
      <bpmn:outgoing>Flow_coerce_to_filter</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="filter_fields" name="Filter Fields">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="plugin" value="field-filter" />
          <camunda:property name="pluginConfig" value="keep=order_id,customer_name,customer_email,items,amount,status,timestamp" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_coerce_to_filter</bpmn:incoming>
      <bpmn:outgoing>Flow_filter_to_route</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="route_by_amount" name="Route by Amount">
      <bpmn:incoming>Flow_filter_to_route</bpmn:incoming>
      <bpmn:outgoing>Flow_high_value</bpmn:outgoing>
      <bpmn:outgoing>Flow_low_value</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="enrich_high_value" name="Enrich High Value">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="plugin" value="kv-enricher" />
          <camunda:property name="pluginConfig" value="keyField=customer_email" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_high_value</bpmn:incoming>
      <bpmn:outgoing>Flow_high_enrich_to_validate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="validate_high_value" name="Validate High Value">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="plugin" value="json-schema-validator" />
          <camunda:property name="pluginConfig" value="required=order_id,amount,customer_email" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_high_enrich_to_validate</bpmn:incoming>
      <bpmn:outgoing>Flow_high_validate_to_inject</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="inject_trace_id" name="Inject Trace ID">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="plugin" value="uuid-inject" />
          <camunda:property name="pluginConfig" value="fields=trace_id;strategy=uuid4" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_high_validate_to_inject</bpmn:incoming>
      <bpmn:outgoing>Flow_inject_to_normalize_ts</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="normalize_timestamp" name="Normalize Timestamp">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="plugin" value="timestamp-normalize" />
          <camunda:property name="pluginConfig" value="fields=timestamp;from=epoch_ms;to=ISO8601" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_inject_to_normalize_ts</bpmn:incoming>
      <bpmn:outgoing>Flow_normalize_to_high_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_High" name="Sink to warehouse">
      <bpmn:incoming>Flow_normalize_to_high_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="mask_customer_email_low_value" name="Mask Customer Email (Low Value)">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="plugin" value="mask" />
          <camunda:property name="pluginConfig" value="fields=customer_email;mask=*;preserve=2" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_low_value</bpmn:incoming>
      <bpmn:outgoing>Flow_mask_to_low_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Low" name="Sink to data lake">
      <bpmn:incoming>Flow_mask_to_low_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_to_normalize" sourceRef="StartEvent_1" targetRef="normalize_order" />
    <bpmn:sequenceFlow id="Flow_normalize_to_coerce" sourceRef="normalize_order" targetRef="coerce_types" />
    <bpmn:sequenceFlow id="Flow_coerce_to_filter" sourceRef="coerce_types" targetRef="filter_fields" />
    <bpmn:sequenceFlow id="Flow_filter_to_route" sourceRef="filter_fields" targetRef="route_by_amount" />
    <bpmn:sequenceFlow id="Flow_high_value" sourceRef="route_by_amount" targetRef="enrich_high_value">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${amount &gt; 1000}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_low_value" sourceRef="route_by_amount" targetRef="mask_customer_email_low_value">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${amount &lt;= 1000}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_high_enrich_to_validate" sourceRef="enrich_high_value" targetRef="validate_high_value" />
    <bpmn:sequenceFlow id="Flow_high_validate_to_inject" sourceRef="validate_high_value" targetRef="inject_trace_id" />
    <bpmn:sequenceFlow id="Flow_inject_to_normalize_ts" sourceRef="inject_trace_id" targetRef="normalize_timestamp" />
    <bpmn:sequenceFlow id="Flow_normalize_to_high_end" sourceRef="normalize_timestamp" targetRef="EndEvent_High" />
    <bpmn:sequenceFlow id="Flow_mask_to_low_end" sourceRef="mask_customer_email_low_value" targetRef="EndEvent_Low" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_order_events_pipeline">
    <bpmndi:BPMNPlane id="BPMNPlane_order_events_pipeline" bpmnElement="order_events_pipeline">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="normalize_order_di" bpmnElement="normalize_order">
        <dc:Bounds x="175" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="coerce_types_di" bpmnElement="coerce_types">
        <dc:Bounds x="325" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="filter_fields_di" bpmnElement="filter_fields">
        <dc:Bounds x="475" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="route_by_amount_di" bpmnElement="route_by_amount" isMarkerVisible="true">
        <dc:Bounds x="650" y="45" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="enrich_high_value_di" bpmnElement="enrich_high_value">
        <dc:Bounds x="775" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="validate_high_value_di" bpmnElement="validate_high_value">
        <dc:Bounds x="925" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="inject_trace_id_di" bpmnElement="inject_trace_id">
        <dc:Bounds x="1075" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="normalize_timestamp_di" bpmnElement="normalize_timestamp">
        <dc:Bounds x="1225" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_High_di" bpmnElement="EndEvent_High">
        <dc:Bounds x="1407" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="mask_customer_email_low_value_di" bpmnElement="mask_customer_email_low_value">
        <dc:Bounds x="775" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Low_di" bpmnElement="EndEvent_Low">
        <dc:Bounds x="957" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_to_normalize_di" bpmnElement="Flow_to_normalize">
        <di:waypoint x="93" y="70" />
        <di:waypoint x="175" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_normalize_to_coerce_di" bpmnElement="Flow_normalize_to_coerce">
        <di:waypoint x="275" y="70" />
        <di:waypoint x="325" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_coerce_to_filter_di" bpmnElement="Flow_coerce_to_filter">
        <di:waypoint x="425" y="70" />
        <di:waypoint x="475" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_filter_to_route_di" bpmnElement="Flow_filter_to_route">
        <di:waypoint x="575" y="70" />
        <di:waypoint x="650" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_high_value_di" bpmnElement="Flow_high_value">
        <di:waypoint x="700" y="70" />
        <di:waypoint x="775" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_low_value_di" bpmnElement="Flow_low_value">
        <di:waypoint x="675" y="95" />
        <di:waypoint x="675" y="210" />
        <di:waypoint x="775" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_high_enrich_to_validate_di" bpmnElement="Flow_high_enrich_to_validate">
        <di:waypoint x="875" y="70" />
        <di:waypoint x="925" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_high_validate_to_inject_di" bpmnElement="Flow_high_validate_to_inject">
        <di:waypoint x="1025" y="70" />
        <di:waypoint x="1075" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_inject_to_normalize_ts_di" bpmnElement="Flow_inject_to_normalize_ts">
        <di:waypoint x="1175" y="70" />
        <di:waypoint x="1225" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_normalize_to_high_end_di" bpmnElement="Flow_normalize_to_high_end">
        <di:waypoint x="1325" y="70" />
        <di:waypoint x="1407" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_mask_to_low_end_di" bpmnElement="Flow_mask_to_low_end">
        <di:waypoint x="875" y="210" />
        <di:waypoint x="957" y="210" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
