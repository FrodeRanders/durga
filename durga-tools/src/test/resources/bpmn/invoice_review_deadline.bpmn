<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://example.com/bpmn">
  <process id="invoice_review_deadline" name="Invoice Review Deadline" isExecutable="true">
    <startEvent id="start" name="Invoice Received" />
    <sequenceFlow id="flow_start_to_register" sourceRef="start" targetRef="register_invoice" />
    <serviceTask id="register_invoice" name="Register Invoice" />
    <sequenceFlow id="flow_register_to_review" sourceRef="register_invoice" targetRef="review_invoice" />
    <userTask id="review_invoice" name="Review Invoice" />
    <sequenceFlow id="flow_review_to_notify" sourceRef="review_invoice" targetRef="notify_requester" />
    <boundaryEvent id="review_timeout" name="Review Timeout" attachedToRef="review_invoice">
      <timerEventDefinition>
        <timeDuration>PT15S</timeDuration>
      </timerEventDefinition>
    </boundaryEvent>
    <sequenceFlow id="flow_timeout_to_escalate" sourceRef="review_timeout" targetRef="escalate_review" />
    <serviceTask id="notify_requester" name="Notify Requester" />
    <sequenceFlow id="flow_notify_to_end" sourceRef="notify_requester" targetRef="end_completed" />
    <serviceTask id="escalate_review" name="Escalate Review" />
    <sequenceFlow id="flow_escalate_to_end" sourceRef="escalate_review" targetRef="end_timed_out" />
    <endEvent id="end_completed" name="Review Completed" />
    <endEvent id="end_timed_out" name="Review Timed Out" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_invoice_review_deadline">
    <bpmndi:BPMNPlane id="BPMNPlane_invoice_review_deadline" bpmnElement="invoice_review_deadline">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <omgdc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="register_invoice_di" bpmnElement="register_invoice">
        <omgdc:Bounds x="25" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_invoice_di" bpmnElement="review_invoice">
        <omgdc:Bounds x="25" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_timeout_di" bpmnElement="review_timeout">
        <omgdc:Bounds x="57" y="372" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="notify_requester_di" bpmnElement="notify_requester">
        <omgdc:Bounds x="25" y="450" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="escalate_review_di" bpmnElement="escalate_review">
        <omgdc:Bounds x="25" y="590" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_completed_di" bpmnElement="end_completed">
        <omgdc:Bounds x="57" y="752" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_timed_out_di" bpmnElement="end_timed_out">
        <omgdc:Bounds x="57" y="892" width="36" height="36" />
      </bpmndi:BPMNShape>
    <bpmndi:BPMNEdge id="flow_start_to_register_di" bpmnElement="flow_start_to_register"><omgdi:waypoint x="75" y="88" /><omgdi:waypoint x="75" y="170" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_register_to_review_di" bpmnElement="flow_register_to_review"><omgdi:waypoint x="75" y="250" /><omgdi:waypoint x="75" y="310" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_review_to_notify_di" bpmnElement="flow_review_to_notify"><omgdi:waypoint x="75" y="390" /><omgdi:waypoint x="75" y="450" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_timeout_to_escalate_di" bpmnElement="flow_timeout_to_escalate"><omgdi:waypoint x="75" y="408" /><omgdi:waypoint x="75" y="590" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_notify_to_end_di" bpmnElement="flow_notify_to_end"><omgdi:waypoint x="75" y="530" /><omgdi:waypoint x="75" y="752" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_escalate_to_end_di" bpmnElement="flow_escalate_to_end"><omgdi:waypoint x="75" y="670" /><omgdi:waypoint x="75" y="892" /></bpmndi:BPMNEdge></bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>