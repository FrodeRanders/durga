<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Properties>
        <Property name="log-path">${sys:log-path:-target}</Property>
    </Properties>

    <Appenders>
        <RollingFile name="INTERNAL"
                     fileName="${log-path}/durga.log"
                     filePattern="${log-path}/durga-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout>
                <pattern>[%t] [%-5level] %c{1}: %m%n</pattern>
            </PatternLayout>
            <Policies>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="9"/>
        </RollingFile>

        <RollingFile name="STATISTICS"
                     fileName="${log-path}/statistics.log"
                     filePattern="${log-path}/statistics-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS}: %m%n</pattern>
            </PatternLayout>
            <Policies>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="9"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Logger name="org.gautelis.durga" level="debug"/>

        <Logger name="STATISTICS" level="INFO">
            <AppenderRef ref="STATISTICS"/>
        </Logger>

        <Root level="INFO">
            <AppenderRef ref="INTERNAL"/>
        </Root>
    </Loggers>
</Configuration>
