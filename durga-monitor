#!/usr/bin/env bash
set -euo pipefail

JAR="target/durga-1.0-SNAPSHOT.jar"
URL="${DURGA_URL:-http://localhost:8081}"

if [[ ! -f "$JAR" ]]; then
    echo "Run 'mvn -q package -DskipTests' first" >&2
    exit 1
fi

exec java -cp "$JAR" org.gautelis.durga.monitoring.ProcessMonitoringClient "$URL" "$@"
