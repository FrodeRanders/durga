<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://example.com/bpmn">
  <escalation id="review_escalation_def" name="Review Escalated" escalationCode="review_invoice_escalated" />
  <process id="invoice_review_escalation" name="Invoice Review Escalation" isExecutable="true">
    <startEvent id="start" name="Invoice Received" />
    <sequenceFlow id="flow_start_to_register" sourceRef="start" targetRef="register_invoice" />
    <serviceTask id="register_invoice" name="Register Invoice" />
    <sequenceFlow id="flow_register_to_review" sourceRef="register_invoice" targetRef="review_invoice" />
    <userTask id="review_invoice" name="Review Invoice" />
    <sequenceFlow id="flow_review_to_notify" sourceRef="review_invoice" targetRef="notify_requester" />
    <boundaryEvent id="review_escalation" name="Review Escalation" attachedToRef="review_invoice">
      <escalationEventDefinition escalationRef="review_escalation_def" />
    </boundaryEvent>
    <sequenceFlow id="flow_escalation_to_reject" sourceRef="review_escalation" targetRef="reject_invoice" />
    <serviceTask id="notify_requester" name="Notify Requester" />
    <sequenceFlow id="flow_notify_to_end" sourceRef="notify_requester" targetRef="end_completed" />
    <serviceTask id="reject_invoice" name="Reject Invoice" />
    <sequenceFlow id="flow_reject_to_end" sourceRef="reject_invoice" targetRef="end_rejected" />
    <endEvent id="end_completed" name="Invoice Approved" />
    <endEvent id="end_rejected" name="Invoice Escalated" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_invoice_review_escalation">
    <bpmndi:BPMNPlane id="BPMNPlane_invoice_review_escalation" bpmnElement="invoice_review_escalation">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <omgdc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="register_invoice_di" bpmnElement="register_invoice">
        <omgdc:Bounds x="25" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_invoice_di" bpmnElement="review_invoice">
        <omgdc:Bounds x="25" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_escalation_di" bpmnElement="review_escalation">
        <omgdc:Bounds x="57" y="372" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="notify_requester_di" bpmnElement="notify_requester">
        <omgdc:Bounds x="25" y="450" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="reject_invoice_di" bpmnElement="reject_invoice">
        <omgdc:Bounds x="25" y="590" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_completed_di" bpmnElement="end_completed">
        <omgdc:Bounds x="57" y="752" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_rejected_di" bpmnElement="end_rejected">
        <omgdc:Bounds x="57" y="892" width="36" height="36" />
      </bpmndi:BPMNShape>
    <bpmndi:BPMNEdge id="flow_start_to_register_di" bpmnElement="flow_start_to_register"><omgdi:waypoint x="75" y="88" /><omgdi:waypoint x="75" y="170" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_register_to_review_di" bpmnElement="flow_register_to_review"><omgdi:waypoint x="75" y="250" /><omgdi:waypoint x="75" y="310" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_review_to_notify_di" bpmnElement="flow_review_to_notify"><omgdi:waypoint x="75" y="390" /><omgdi:waypoint x="75" y="450" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_escalation_to_reject_di" bpmnElement="flow_escalation_to_reject"><omgdi:waypoint x="75" y="408" /><omgdi:waypoint x="75" y="590" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_notify_to_end_di" bpmnElement="flow_notify_to_end"><omgdi:waypoint x="75" y="530" /><omgdi:waypoint x="75" y="752" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_reject_to_end_di" bpmnElement="flow_reject_to_end"><omgdi:waypoint x="75" y="670" /><omgdi:waypoint x="75" y="892" /></bpmndi:BPMNEdge></bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>