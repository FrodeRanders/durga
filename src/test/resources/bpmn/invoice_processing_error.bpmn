<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://example.com/bpmn">
  <error id="processing_error_def" name="Processing Error" errorCode="register_invoice_failed" />
  <process id="invoice_processing_error" name="Invoice Processing Error" isExecutable="true">
    <startEvent id="start" name="Invoice Received" />
    <sequenceFlow id="flow_start_to_register" sourceRef="start" targetRef="register_invoice" />
    <serviceTask id="register_invoice" name="Register Invoice" />
    <sequenceFlow id="flow_register_to_notify" sourceRef="register_invoice" targetRef="notify_requester" />
    <boundaryEvent id="register_error" name="Register Error" attachedToRef="register_invoice">
      <errorEventDefinition errorRef="processing_error_def" />
    </boundaryEvent>
    <sequenceFlow id="flow_error_to_reject" sourceRef="register_error" targetRef="reject_invoice" />
    <serviceTask id="notify_requester" name="Notify Requester" />
    <sequenceFlow id="flow_notify_to_end" sourceRef="notify_requester" targetRef="end_completed" />
    <serviceTask id="reject_invoice" name="Reject Invoice" />
    <sequenceFlow id="flow_reject_to_end" sourceRef="reject_invoice" targetRef="end_failed" />
    <endEvent id="end_completed" name="Invoice Processed" />
    <endEvent id="end_failed" name="Invoice Rejected" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_invoice_processing_error">
    <bpmndi:BPMNPlane id="BPMNPlane_invoice_processing_error" bpmnElement="invoice_processing_error">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <omgdc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="register_invoice_di" bpmnElement="register_invoice">
        <omgdc:Bounds x="25" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="register_error_di" bpmnElement="register_error">
        <omgdc:Bounds x="57" y="232" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="notify_requester_di" bpmnElement="notify_requester">
        <omgdc:Bounds x="25" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="reject_invoice_di" bpmnElement="reject_invoice">
        <omgdc:Bounds x="25" y="450" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_completed_di" bpmnElement="end_completed">
        <omgdc:Bounds x="57" y="612" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_failed_di" bpmnElement="end_failed">
        <omgdc:Bounds x="57" y="752" width="36" height="36" />
      </bpmndi:BPMNShape>
    <bpmndi:BPMNEdge id="flow_start_to_register_di" bpmnElement="flow_start_to_register"><omgdi:waypoint x="75" y="88" /><omgdi:waypoint x="75" y="170" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_register_to_notify_di" bpmnElement="flow_register_to_notify"><omgdi:waypoint x="75" y="250" /><omgdi:waypoint x="75" y="310" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_error_to_reject_di" bpmnElement="flow_error_to_reject"><omgdi:waypoint x="75" y="268" /><omgdi:waypoint x="75" y="450" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_notify_to_end_di" bpmnElement="flow_notify_to_end"><omgdi:waypoint x="75" y="390" /><omgdi:waypoint x="75" y="612" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_reject_to_end_di" bpmnElement="flow_reject_to_end"><omgdi:waypoint x="75" y="530" /><omgdi:waypoint x="75" y="752" /></bpmndi:BPMNEdge></bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>