<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://example.com/bpmn" exporter="Camunda Modeler" exporterVersion="5.48.0">
  <process id="invoice_receipt" name="Invoice Receipt" isExecutable="true">
    <startEvent id="start" name="Invoice Received" />
    <sequenceFlow id="flow_start_to_register" sourceRef="start" targetRef="register_invoice" />
    <serviceTask id="register_invoice" name="Register Invoice" />
    <sequenceFlow id="flow_register_to_review" sourceRef="register_invoice" targetRef="review_invoice" />
    <userTask id="review_invoice" name="Review Invoice" />
    <sequenceFlow id="flow_review_to_gateway" sourceRef="review_invoice" targetRef="invoice_approved" />
    <exclusiveGateway id="invoice_approved" name="Invoice Approved?" />
    <sequenceFlow id="flow_approved_to_notify" name="Yes" sourceRef="invoice_approved" targetRef="notify_requester">
      <conditionExpression xsi:type="tFormalExpression">${approved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_rejected_to_reject" name="No" sourceRef="invoice_approved" targetRef="reject_invoice">
      <conditionExpression xsi:type="tFormalExpression">${approved == false}</conditionExpression>
    </sequenceFlow>
    <serviceTask id="notify_requester" name="Notify Requester" />
    <sequenceFlow id="flow_notify_to_end" sourceRef="notify_requester" targetRef="end_approved" />
    <serviceTask id="reject_invoice" name="Reject Invoice" />
    <sequenceFlow id="flow_reject_to_end" sourceRef="reject_invoice" targetRef="end_rejected" />
    <endEvent id="end_approved" name="Invoice Approved" />
    <endEvent id="end_rejected" name="Invoice Rejected" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_invoice_receipt">
    <bpmndi:BPMNPlane id="BPMNPlane_invoice_receipt" bpmnElement="invoice_receipt">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <omgdc:Bounds x="182" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="158" y="228" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="invoice_approved_di" bpmnElement="invoice_approved" isMarkerVisible="true">
        <omgdc:Bounds x="585" y="185" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="643" y="196" width="54" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_rejected_di" bpmnElement="end_rejected">
        <omgdc:Bounds x="862" y="285" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="839" y="321" width="82" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="reject_invoice_di" bpmnElement="reject_invoice">
        <omgdc:Bounds x="720" y="263" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_approved_di" bpmnElement="end_approved">
        <omgdc:Bounds x="862" y="99" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="838" y="135" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="notify_requester_di" bpmnElement="notify_requester">
        <omgdc:Bounds x="720" y="77" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_invoice_di" bpmnElement="review_invoice">
        <omgdc:Bounds x="440" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="register_invoice_di" bpmnElement="register_invoice">
        <omgdc:Bounds x="290" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flow_start_to_register_di" bpmnElement="flow_start_to_register">
        <omgdi:waypoint x="218" y="210" />
        <omgdi:waypoint x="290" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_register_to_review_di" bpmnElement="flow_register_to_review">
        <omgdi:waypoint x="390" y="210" />
        <omgdi:waypoint x="440" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_review_to_gateway_di" bpmnElement="flow_review_to_gateway">
        <omgdi:waypoint x="540" y="210" />
        <omgdi:waypoint x="585" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_approved_to_notify_di" bpmnElement="flow_approved_to_notify">
        <omgdi:waypoint x="610" y="185" />
        <omgdi:waypoint x="610" y="117" />
        <omgdi:waypoint x="720" y="117" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="616" y="143.5" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_rejected_to_reject_di" bpmnElement="flow_rejected_to_reject">
        <omgdi:waypoint x="610" y="235" />
        <omgdi:waypoint x="610" y="303" />
        <omgdi:waypoint x="720" y="303" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="618" y="261.5" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_reject_to_end_di" bpmnElement="flow_reject_to_end">
        <omgdi:waypoint x="820" y="303" />
        <omgdi:waypoint x="862" y="303" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_notify_to_end_di" bpmnElement="flow_notify_to_end">
        <omgdi:waypoint x="820" y="117" />
        <omgdi:waypoint x="862" y="117" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
