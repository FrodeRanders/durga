<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://example.com/bpmn">
  <process id="invoice_nested_subprocess" name="Invoice Nested Subprocess" isExecutable="true">
    <startEvent id="start" name="Invoice Received" />
    <sequenceFlow id="flow_start_to_register" sourceRef="start" targetRef="register_invoice" />
    <serviceTask id="register_invoice" name="Register Invoice" />
    <sequenceFlow id="flow_register_to_outer_scope" sourceRef="register_invoice" targetRef="review_scope" />
    <subProcess id="review_scope" name="Review Scope">
      <startEvent id="review_scope_start" name="Enter Review Scope" />
      <sequenceFlow id="flow_outer_start_to_inner_scope" sourceRef="review_scope_start" targetRef="approval_scope" />
      <subProcess id="approval_scope" name="Approval Scope">
        <startEvent id="approval_scope_start" name="Enter Approval Scope" />
        <sequenceFlow id="flow_inner_start_to_review" sourceRef="approval_scope_start" targetRef="review_invoice" />
        <userTask id="review_invoice" name="Review Invoice" />
        <sequenceFlow id="flow_review_to_approve" sourceRef="review_invoice" targetRef="approve_invoice" />
        <serviceTask id="approve_invoice" name="Approve Invoice" />
        <sequenceFlow id="flow_approve_to_inner_end" sourceRef="approve_invoice" targetRef="approval_scope_end" />
        <endEvent id="approval_scope_end" name="Approval Finished" />
      </subProcess>
      <sequenceFlow id="flow_inner_scope_to_outer_end" sourceRef="approval_scope" targetRef="review_scope_end" />
      <endEvent id="review_scope_end" name="Review Finished" />
    </subProcess>
    <sequenceFlow id="flow_outer_scope_to_notify" sourceRef="review_scope" targetRef="notify_requester" />
    <serviceTask id="notify_requester" name="Notify Requester" />
    <sequenceFlow id="flow_notify_to_end" sourceRef="notify_requester" targetRef="end_completed" />
    <endEvent id="end_completed" name="Invoice Reviewed" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_invoice_nested_subprocess">
    <bpmndi:BPMNPlane id="BPMNPlane_invoice_nested_subprocess" bpmnElement="invoice_nested_subprocess">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <omgdc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="register_invoice_di" bpmnElement="register_invoice">
        <omgdc:Bounds x="25" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_scope_di" bpmnElement="review_scope">
        <omgdc:Bounds x="25" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="notify_requester_di" bpmnElement="notify_requester">
        <omgdc:Bounds x="25" y="450" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_completed_di" bpmnElement="end_completed">
        <omgdc:Bounds x="57" y="612" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_scope_start_di" bpmnElement="review_scope_start">
        <omgdc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="approval_scope_di" bpmnElement="approval_scope">
        <omgdc:Bounds x="25" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_scope_end_di" bpmnElement="review_scope_end">
        <omgdc:Bounds x="57" y="332" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="approval_scope_start_di" bpmnElement="approval_scope_start">
        <omgdc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_invoice_di" bpmnElement="review_invoice">
        <omgdc:Bounds x="25" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="approve_invoice_di" bpmnElement="approve_invoice">
        <omgdc:Bounds x="25" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="approval_scope_end_di" bpmnElement="approval_scope_end">
        <omgdc:Bounds x="57" y="472" width="36" height="36" />
      </bpmndi:BPMNShape>
    <bpmndi:BPMNEdge id="flow_start_to_register_di" bpmnElement="flow_start_to_register"><omgdi:waypoint x="75" y="88" /><omgdi:waypoint x="75" y="170" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_register_to_outer_scope_di" bpmnElement="flow_register_to_outer_scope"><omgdi:waypoint x="75" y="250" /><omgdi:waypoint x="75" y="310" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_outer_scope_to_notify_di" bpmnElement="flow_outer_scope_to_notify"><omgdi:waypoint x="75" y="390" /><omgdi:waypoint x="75" y="450" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="flow_notify_to_end_di" bpmnElement="flow_notify_to_end"><omgdi:waypoint x="75" y="530" /><omgdi:waypoint x="75" y="612" /></bpmndi:BPMNEdge></bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>