<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" targetNamespace="http://example.com/bpmn">
  <message id="message_cancel_invoice" name="cancel_invoice" />
  <process id="invoice_event_subprocess_interrupting_message" name="Invoice Event Subprocess Interrupting Message" isExecutable="true">
    <startEvent id="start" name="Invoice Received" />
    <sequenceFlow id="flow_start_to_register" sourceRef="start" targetRef="register_invoice" />
    <serviceTask id="register_invoice" name="Register Invoice" />
    <sequenceFlow id="flow_register_to_review" sourceRef="register_invoice" targetRef="review_invoice" />
    <userTask id="review_invoice" name="Review Invoice" />
    <sequenceFlow id="flow_review_to_notify" sourceRef="review_invoice" targetRef="notify_requester" />
    <serviceTask id="notify_requester" name="Notify Requester" />
    <sequenceFlow id="flow_notify_to_end" sourceRef="notify_requester" targetRef="end_completed" />
    <subProcess id="invoice_cancellation_scope" name="Invoice Cancellation Scope" triggeredByEvent="true">
      <startEvent id="cancel_start" name="Cancel Invoice">
        <messageEventDefinition messageRef="message_cancel_invoice" />
      </startEvent>
      <sequenceFlow id="flow_cancel_start_to_reject" sourceRef="cancel_start" targetRef="reject_invoice" />
      <serviceTask id="reject_invoice" name="Reject Invoice" />
      <sequenceFlow id="flow_reject_to_cancel_end" sourceRef="reject_invoice" targetRef="cancel_end" />
      <endEvent id="cancel_end" name="Invoice Cancelled" />
    </subProcess>
    <endEvent id="end_completed" name="Invoice Completed" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_invoice_event_subprocess_interrupting_message">
    <bpmndi:BPMNPlane id="BPMNPlane_invoice_event_subprocess_interrupting_message" bpmnElement="invoice_event_subprocess_interrupting_message">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <omgdc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="register_invoice_di" bpmnElement="register_invoice">
        <omgdc:Bounds x="25" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_invoice_di" bpmnElement="review_invoice">
        <omgdc:Bounds x="25" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="notify_requester_di" bpmnElement="notify_requester">
        <omgdc:Bounds x="25" y="450" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="invoice_cancellation_scope_di" bpmnElement="invoice_cancellation_scope">
        <omgdc:Bounds x="25" y="590" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_completed_di" bpmnElement="end_completed">
        <omgdc:Bounds x="57" y="752" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="cancel_start_di" bpmnElement="cancel_start">
        <omgdc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="reject_invoice_di" bpmnElement="reject_invoice">
        <omgdc:Bounds x="25" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="cancel_end_di" bpmnElement="cancel_end">
        <omgdc:Bounds x="57" y="332" width="36" height="36" />
      </bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
