<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="log_processing_pipeline" name="Log Processing Pipeline" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Ingest logs">
      <bpmn:outgoing>Flow_to_regex</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="extract_fields" name="Extract Log Fields">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="plugin" value="regex-extract" />
          <camunda:property name="pluginConfig" value="source=raw;pattern=(?&#60;ip&#62;\d+\.\d+\.\d+\.\d+)\s+\S+\s+\S+\s+\[(?&#60;timestamp&#62;[^\]]+)\]\s+&#34;(?&#60;method&#62;\w+)\s+(?&#60;path&#62;[^\s]+)[^&#34;]*&#34;\s+(?&#60;status&#62;\d+)\s+(?&#60;bytes&#62;\d+);target=parsed" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_regex</bpmn:incoming>
      <bpmn:outgoing>Flow_regex_to_coerce</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="coerce_log_types" name="Coerce Log Types">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="plugin" value="type-coercer" />
          <camunda:property name="pluginConfig" value="parsed.status:int, parsed.bytes:int" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_regex_to_coerce</bpmn:incoming>
      <bpmn:outgoing>Flow_coerce_to_template</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="format_message" name="Format Message">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="plugin" value="string-template" />
          <camunda:property name="pluginConfig" value="template=${parsed.method} ${parsed.path} returned ${parsed.status} (${parsed.bytes} bytes) from ${parsed.ip}" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_coerce_to_template</bpmn:incoming>
      <bpmn:outgoing>Flow_template_to_flatten</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="flatten_for_index" name="Flatten for Index">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="plugin" value="json-flatten" />
          <camunda:property name="pluginConfig" value="direction=flatten;separator=.;maxDepth=2" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_template_to_flatten</bpmn:incoming>
      <bpmn:outgoing>Flow_flatten_to_validate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="validate_log" name="Validate Log Record">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="plugin" value="json-schema-validator" />
          <camunda:property name="pluginConfig" value="required=parsed.ip,parsed.timestamp,parsed.method,parsed.path,parsed.status" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_flatten_to_validate</bpmn:incoming>
      <bpmn:outgoing>Flow_validate_to_mask</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="mask_ip" name="Mask IP Address">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="plugin" value="mask" />
          <camunda:property name="pluginConfig" value="fields=parsed.ip;mask=#;preserve=0" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_validate_to_mask</bpmn:incoming>
      <bpmn:outgoing>Flow_mask_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_1" name="Sink to search index">
      <bpmn:incoming>Flow_mask_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_to_regex" sourceRef="StartEvent_1" targetRef="extract_fields" />
    <bpmn:sequenceFlow id="Flow_regex_to_coerce" sourceRef="extract_fields" targetRef="coerce_log_types" />
    <bpmn:sequenceFlow id="Flow_coerce_to_template" sourceRef="coerce_log_types" targetRef="format_message" />
    <bpmn:sequenceFlow id="Flow_template_to_flatten" sourceRef="format_message" targetRef="flatten_for_index" />
    <bpmn:sequenceFlow id="Flow_flatten_to_validate" sourceRef="flatten_for_index" targetRef="validate_log" />
    <bpmn:sequenceFlow id="Flow_validate_to_mask" sourceRef="validate_log" targetRef="mask_ip" />
    <bpmn:sequenceFlow id="Flow_mask_to_end" sourceRef="mask_ip" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_log_processing_pipeline">
    <bpmndi:BPMNPlane id="BPMNPlane_log_processing_pipeline" bpmnElement="log_processing_pipeline">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="extract_fields_di" bpmnElement="extract_fields">
        <dc:Bounds x="175" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="coerce_log_types_di" bpmnElement="coerce_log_types">
        <dc:Bounds x="325" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="format_message_di" bpmnElement="format_message">
        <dc:Bounds x="475" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="flatten_for_index_di" bpmnElement="flatten_for_index">
        <dc:Bounds x="625" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="validate_log_di" bpmnElement="validate_log">
        <dc:Bounds x="775" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="mask_ip_di" bpmnElement="mask_ip">
        <dc:Bounds x="925" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1107" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_to_regex_di" bpmnElement="Flow_to_regex">
        <di:waypoint x="93" y="70" />
        <di:waypoint x="175" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_regex_to_coerce_di" bpmnElement="Flow_regex_to_coerce">
        <di:waypoint x="275" y="70" />
        <di:waypoint x="325" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_coerce_to_template_di" bpmnElement="Flow_coerce_to_template">
        <di:waypoint x="425" y="70" />
        <di:waypoint x="475" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_template_to_flatten_di" bpmnElement="Flow_template_to_flatten">
        <di:waypoint x="575" y="70" />
        <di:waypoint x="625" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_flatten_to_validate_di" bpmnElement="Flow_flatten_to_validate">
        <di:waypoint x="725" y="70" />
        <di:waypoint x="775" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_validate_to_mask_di" bpmnElement="Flow_validate_to_mask">
        <di:waypoint x="875" y="70" />
        <di:waypoint x="925" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_mask_to_end_di" bpmnElement="Flow_mask_to_end">
        <di:waypoint x="1025" y="70" />
        <di:waypoint x="1107" y="70" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
