<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://example.com/bpmn">
  <process id="invoice_review_reminder_non_interrupting" name="Invoice Review Reminder Non Interrupting" isExecutable="true">
    <startEvent id="start" name="Invoice Received"/>
    <sequenceFlow id="flow_start_to_register" sourceRef="start" targetRef="register_invoice"/>

    <serviceTask id="register_invoice" name="Register Invoice"/>
    <sequenceFlow id="flow_register_to_review" sourceRef="register_invoice" targetRef="review_invoice"/>

    <userTask id="review_invoice" name="Review Invoice"/>
    <sequenceFlow id="flow_review_to_notify" sourceRef="review_invoice" targetRef="notify_requester"/>

    <boundaryEvent id="review_reminder" name="Review Reminder" attachedToRef="review_invoice" cancelActivity="false">
      <timerEventDefinition>
        <timeDuration>PT15S</timeDuration>
      </timerEventDefinition>
    </boundaryEvent>
    <sequenceFlow id="flow_reminder_to_send_reminder" sourceRef="review_reminder" targetRef="send_review_reminder"/>

    <serviceTask id="send_review_reminder" name="Send Review Reminder"/>
    <sequenceFlow id="flow_send_reminder_to_end" sourceRef="send_review_reminder" targetRef="end_reminder_sent"/>

    <serviceTask id="notify_requester" name="Notify Requester"/>
    <sequenceFlow id="flow_notify_to_end" sourceRef="notify_requester" targetRef="end_completed"/>

    <endEvent id="end_completed" name="Review Completed"/>
    <endEvent id="end_reminder_sent" name="Reminder Sent"/>
  </process>
</definitions>
