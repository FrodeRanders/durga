demoScenarioRunnerClass(packageName, className, processId, firstTask, lastTask, eventsTopic) ::= <<
package %packageName%;

import org.apache.kafka.clients.producer.KafkaProducer;
import org.apache.kafka.clients.producer.ProducerConfig;
import org.apache.kafka.clients.producer.ProducerRecord;
import org.apache.kafka.common.serialization.StringSerializer;
import org.gautelis.durga.ProcessEvent;
import tools.jackson.databind.ObjectMapper;

import java.io.IOException;
import java.nio.file.Files;
import java.nio.file.Path;
import java.time.Instant;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;
import java.util.Properties;
import java.util.UUID;

public class %className% {
    private static final String TOPIC = "%eventsTopic%";
    private static final ObjectMapper MAPPER = new ObjectMapper();

    public static void main(String[] args) {
        String bootstrap = args.length > 0 ? args[0] : "localhost:9094";
        String scenario = args.length > 1 ? args[1] : "happy";
        String processInstanceId = args.length > 2 ? args[2] : UUID.randomUUID().toString();

        if (!List.of("happy", "stuck", "failed").contains(scenario)) {
            throw new IllegalArgumentException("Scenario must be one of: happy, stuck, failed");
        }

        TaskPayloads payloads = loadTaskPayloads();
        String correlationId = UUID.randomUUID().toString();
        String businessKey = payloads.businessKeyExample() != null ? payloads.businessKeyExample() : "%processId%-demo-001";

        Properties props = new Properties();
        props.put(ProducerConfig.BOOTSTRAP_SERVERS_CONFIG, bootstrap);
        props.put(ProducerConfig.KEY_SERIALIZER_CLASS_CONFIG, StringSerializer.class.getName());
        props.put(ProducerConfig.VALUE_SERIALIZER_CLASS_CONFIG, StringSerializer.class.getName());

        try (KafkaProducer<String, String> producer = new KafkaProducer<>(props)) {
            publish(producer, processInstanceId, event(processInstanceId, correlationId, businessKey,
                    "start", Map.of("source", "generated-demo", "scenario", scenario),
                    ProcessEvent.Status.STARTED, null, ProcessEvent.EventType.PROCESS_STARTED));

            switch (scenario) {
                case "happy" -> {
                    publishActivityLifecycle(producer, processInstanceId, correlationId, businessKey, payloads.task("%firstTask%"), "%firstTask%");
                    if (!"%firstTask%".equals("%lastTask%")) {
                        publishActivityLifecycle(producer, processInstanceId, correlationId, businessKey, payloads.task("%lastTask%"), "%lastTask%");
                    }
                    publish(producer, processInstanceId, event(processInstanceId, correlationId, businessKey,
                            "completed", payloads.task("%lastTask%"),
                            ProcessEvent.Status.COMPLETED, null, ProcessEvent.EventType.PROCESS_COMPLETED));
                }
                case "stuck" -> publish(producer, processInstanceId, event(processInstanceId, correlationId, businessKey,
                        "%lastTask%", payloads.task("%lastTask%"),
                        ProcessEvent.Status.STARTED, null, ProcessEvent.EventType.ACTIVITY_ENTERED));
                case "failed" -> {
                    publish(producer, processInstanceId, event(processInstanceId, correlationId, businessKey,
                            "%lastTask%", payloads.task("%lastTask%"),
                            ProcessEvent.Status.STARTED, null, ProcessEvent.EventType.ACTIVITY_ENTERED));
                    publish(producer, processInstanceId, event(processInstanceId, correlationId, businessKey,
                            "%lastTask%", payloads.task("%lastTask%"),
                            ProcessEvent.Status.FAILED,
                            new ProcessEvent.ErrorInfo("Generated demo failure", "GENERATED_DEMO_FAILED"),
                            ProcessEvent.EventType.PROCESS_FAILED));
                }
            }
            producer.flush();
        }

        System.out.println("Published scenario=" + scenario + " for instanceId=" + processInstanceId);
    }

    private static void publishActivityLifecycle(
            KafkaProducer<String, String> producer,
            String processInstanceId,
            String correlationId,
            String businessKey,
            Map<String, Object> payload,
            String activityId
    ) {
        publish(producer, processInstanceId, event(processInstanceId, correlationId, businessKey,
                activityId, payload, ProcessEvent.Status.STARTED, null, ProcessEvent.EventType.ACTIVITY_ENTERED));
        publish(producer, processInstanceId, event(processInstanceId, correlationId, businessKey,
                activityId, payload, ProcessEvent.Status.COMPLETED, null, ProcessEvent.EventType.ACTIVITY_COMPLETED));
    }

    private static ProcessEvent event(
            String processInstanceId,
            String correlationId,
            String businessKey,
            String activityId,
            Map<String, Object> payload,
            ProcessEvent.Status status,
            ProcessEvent.ErrorInfo error,
            ProcessEvent.EventType eventType
    ) {
        return new ProcessEvent(
                processInstanceId,
                "%processId%",
                activityId,
                UUID.randomUUID().toString(),
                correlationId,
                payload,
                status,
                error,
                eventType,
                "v1",
                businessKey,
                Instant.now().toString()
        );
    }

    private static void publish(KafkaProducer<String, String> producer, String key, ProcessEvent event) {
        producer.send(new ProducerRecord<>(TOPIC, key, event.toJson()));
    }

    private static TaskPayloads loadTaskPayloads() {
        Path path = Path.of("task-payloads.json");
        if (!Files.exists(path)) {
            throw new IllegalStateException("Missing task-payloads.json in " + path.toAbsolutePath());
        }
        try {
            return MAPPER.readValue(Files.readString(path), TaskPayloads.class);
        } catch (IOException e) {
            throw new IllegalStateException("Failed to read task-payloads.json", e);
        }
    }

    public record TaskPayloads(String processId, String businessKeyExample, Map<String, Map<String, Object> > tasks) {
        public Map<String, Object> task(String taskId) {
            if (tasks == null) {
                return Map.of();
            }
            Map<String, Object> payload = tasks.get(taskId);
            return payload != null ? new LinkedHashMap<>(payload) : Map.of();
        }
    }
}
>>

taskInputPublisherClass(packageName, className, processId, eventsTopic) ::= <<
package %packageName%;

import org.apache.kafka.clients.producer.KafkaProducer;
import org.apache.kafka.clients.producer.ProducerConfig;
import org.apache.kafka.clients.producer.ProducerRecord;
import org.apache.kafka.common.serialization.StringSerializer;
import org.gautelis.durga.ProcessEvent;
import tools.jackson.databind.ObjectMapper;

import java.io.IOException;
import java.nio.file.Files;
import java.nio.file.Path;
import java.time.Instant;
import java.util.LinkedHashMap;
import java.util.Map;
import java.util.Properties;
import java.util.UUID;

public class %className% {
    private static final ObjectMapper MAPPER = new ObjectMapper();

    public static void main(String[] args) {
        String bootstrap = args.length > 0 ? args[0] : "localhost:9094";
        String taskId = args.length > 1 ? args[1] : null;
        String processInstanceId = args.length > 2 ? args[2] : UUID.randomUUID().toString();

        if (taskId == null || taskId.isBlank()) {
            throw new IllegalArgumentException("Usage: <bootstrap> <task-id> [instance-id]");
        }

        TaskPayloads payloads = loadTaskPayloads();
        Map<String, Object> payload = new LinkedHashMap<>(payloads.task(taskId));
        String correlationId = UUID.randomUUID().toString();
        String businessKey = payloads.businessKeyExample() != null ? payloads.businessKeyExample() : "%processId%-demo-001";
        String topic = "%processId%_" + taskId + "_input";

        ProcessEvent event = new ProcessEvent(
                processInstanceId,
                "%processId%",
                taskId,
                UUID.randomUUID().toString(),
                correlationId,
                payload,
                ProcessEvent.Status.STARTED,
                null,
                ProcessEvent.EventType.ACTIVITY_ENTERED,
                "v1",
                businessKey,
                Instant.now().toString()
        );

        Properties props = new Properties();
        props.put(ProducerConfig.BOOTSTRAP_SERVERS_CONFIG, bootstrap);
        props.put(ProducerConfig.KEY_SERIALIZER_CLASS_CONFIG, StringSerializer.class.getName());
        props.put(ProducerConfig.VALUE_SERIALIZER_CLASS_CONFIG, StringSerializer.class.getName());

        try (KafkaProducer<String, String> producer = new KafkaProducer<>(props)) {
            producer.send(new ProducerRecord<>(topic, processInstanceId, event.toJson()));
            producer.send(new ProducerRecord<>("%eventsTopic%", processInstanceId, event.toJson()));
            producer.flush();
        }

        System.out.println("Published task input for taskId=" + taskId + " instanceId=" + processInstanceId);
    }

    private static TaskPayloads loadTaskPayloads() {
        Path path = Path.of("task-payloads.json");
        if (!Files.exists(path)) {
            throw new IllegalStateException("Missing task-payloads.json in " + path.toAbsolutePath());
        }
        try {
            return MAPPER.readValue(Files.readString(path), TaskPayloads.class);
        } catch (IOException e) {
            throw new IllegalStateException("Failed to read task-payloads.json", e);
        }
    }

    public record TaskPayloads(String processId, String businessKeyExample, Map<String, Map<String, Object> > tasks) {
        public Map<String, Object> task(String taskId) {
            if (tasks == null) {
                return Map.of();
            }
            Map<String, Object> payload = tasks.get(taskId);
            return payload != null ? new LinkedHashMap<>(payload) : Map.of();
        }
    }
}
>>

taskCompletionPublisherClass(packageName, className, processId, eventsTopic) ::= <<
package %packageName%;

import org.apache.kafka.clients.producer.KafkaProducer;
import org.apache.kafka.clients.producer.ProducerConfig;
import org.apache.kafka.clients.producer.ProducerRecord;
import org.apache.kafka.common.serialization.StringSerializer;
import org.gautelis.durga.ProcessEvent;
import tools.jackson.databind.ObjectMapper;

import java.io.IOException;
import java.nio.file.Files;
import java.nio.file.Path;
import java.time.Instant;
import java.util.LinkedHashMap;
import java.util.Map;
import java.util.Properties;
