applicationYaml(processId, tasks, timers, messageTopics, callActivities, subProcesses, eventsTopic) ::= <<
kafka:
  bootstrap:
    servers: ${KAFKA_BOOTSTRAP_SERVERS:localhost:9094}
quarkus:
  application:
    name: %processId%
  http:
    port: ${HTTP_PORT:8080}
  log:
    level: INFO
    category:
      "org.gautelis":
        level: DEBUG
mp:
  messaging:
    incoming:
      process-events-monitor:
        connector: "smallrye-kafka"
        topic: "%eventsTopic%"
        value:
          deserializer: "org.apache.kafka.common.serialization.StringDeserializer"
%tasks:{t|
      %processId%_%t%_input:
        connector: "smallrye-kafka"
        topic: "%processId%_%t%_input"
        value:
          deserializer: "org.apache.kafka.common.serialization.StringDeserializer"
}%
%timers:{t|
      %processId%_%t%_input:
        connector: "smallrye-kafka"
        topic: "%processId%_%t%_input"
        value:
          deserializer: "org.apache.kafka.common.serialization.StringDeserializer"
}%
%messageTopics:{t|
      %t%:
        connector: "smallrye-kafka"
        topic: "%t%"
        value:
          deserializer: "org.apache.kafka.common.serialization.StringDeserializer"
}%
%callActivities:{t|
      %processId%_%t%_reply:
        connector: "smallrye-kafka"
        topic: "%processId%_%t%_reply"
        value:
          deserializer: "org.apache.kafka.common.serialization.StringDeserializer"
}%
%subProcesses:{t|
      %processId%_%t%_input:
        connector: "smallrye-kafka"
        topic: "%processId%_%t%_input"
        value:
          deserializer: "org.apache.kafka.common.serialization.StringDeserializer"
      %processId%_%t%_output:
        connector: "smallrye-kafka"
        topic: "%processId%_%t%_output"
        value:
          deserializer: "org.apache.kafka.common.serialization.StringDeserializer"
}%
    outgoing:
      process-events:
        connector: "smallrye-kafka"
        topic: "%eventsTopic%"
        value:
          serializer: "org.apache.kafka.common.serialization.StringSerializer"
%tasks:{t|
      %processId%_%t%_input:
        connector: "smallrye-kafka"
        topic: "%processId%_%t%_input"
        value:
          serializer: "org.apache.kafka.common.serialization.StringSerializer"
}%
%timers:{t|
      %processId%_%t%_input:
        connector: "smallrye-kafka"
        topic: "%processId%_%t%_input"
        value:
          serializer: "org.apache.kafka.common.serialization.StringSerializer"
}%
%messageTopics:{t|
      %t%:
        connector: "smallrye-kafka"
        topic: "%t%"
        value:
          serializer: "org.apache.kafka.common.serialization.StringSerializer"
}%
%callActivities:{t|
      %processId%_%t%_call:
        connector: "smallrye-kafka"
        topic: "%processId%_%t%_call"
        value:
          serializer: "org.apache.kafka.common.serialization.StringSerializer"
      %processId%_%t%_reply:
        connector: "smallrye-kafka"
        topic: "%processId%_%t%_reply"
        value:
          serializer: "org.apache.kafka.common.serialization.StringSerializer"
}%
%subProcesses:{t|
      %processId%_%t%_input:
        connector: "smallrye-kafka"
        topic: "%processId%_%t%_input"
        value:
          serializer: "org.apache.kafka.common.serialization.StringSerializer"
      %processId%_%t%_output:
        connector: "smallrye-kafka"
        topic: "%processId%_%t%_output"
        value:
          serializer: "org.apache.kafka.common.serialization.StringSerializer"
}%
%tasks:{t|
      %processId%_%t%_output:
        connector: "smallrye-kafka"
        topic: "%processId%_%t%_output"
        value:
          serializer: "org.apache.kafka.common.serialization.StringSerializer"
}%
>>

topicsScript(processId, tasks, timers, messageTopics, callActivities, subProcesses, retentionMs, eventsTopic) ::= <<
#!/usr/bin/env bash
set -euo pipefail

BOOTSTRAP=${BOOTSTRAP:-localhost:9094}
RETENTION_MS=%retentionMs%

topics=(
  "%processId%_start"
  "%processId%_state"
  "%eventsTopic%"
%timers:{t|
  "%processId%_%t%_input"
}%
%messageTopics:{t|
  "%t%"
}%
%callActivities:{t|
  "%processId%_%t%_call"
  "%processId%_%t%_reply"
}%
%subProcesses:{t|
  "%processId%_%t%_input"
  "%processId%_%t%_output"
}%
%tasks:{t|
  "%processId%_%t%_input"
  "%processId%_%t%_output"
}%
)

for topic in "${topics[@]}"; do
  if [[ "$topic" == "%processId%_state" ]]; then
    kafka-topics --bootstrap-server "$BOOTSTRAP" \
      --create --if-not-exists --topic "$topic" \
      --config cleanup.policy=compact
  elif [[ "$RETENTION_MS" == "-1" ]]; then
    kafka-topics --bootstrap-server "$BOOTSTRAP" \
      --create --if-not-exists --topic "$topic" \
      --config retention.ms=-1
  else
    kafka-topics --bootstrap-server "$BOOTSTRAP" \
      --create --if-not-exists --topic "$topic" \
      --config retention.ms="$RETENTION_MS"
  fi
done
>>

runLocalScript(processId, starterClass) ::= <<
#!/usr/bin/env bash
set -euo pipefail

BOOTSTRAP=${BOOTSTRAP:-localhost:9094}
START_KAFKA=${START_KAFKA:-false}
PROFILE=${PROFILE:-dev}

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${ROOT_DIR}/.." && pwd)"

if [[ "$START_KAFKA" == "true" ]]; then
  if [[ -d "${PROJECT_ROOT}/setup" ]]; then
    (cd "${PROJECT_ROOT}/setup" && docker compose up -d)
  else
    echo "setup/ not found at ${PROJECT_ROOT}/setup; skipping Kafka startup."
  fi
fi

mvn -q clean package

JAR="target/%processId%-generated-1.0-SNAPSHOT-all.jar"
if [[ ! -f "$JAR" ]]; then
  echo "Missing shaded jar at $JAR"
  exit 1
fi

echo "===> Starting %processId% with profile=$PROFILE, bootstrap=$BOOTSTRAP"
java -Dquarkus.profile="$PROFILE" \
     -Dkafka.bootstrap.servers="$BOOTSTRAP" \
     -cp "$JAR" org.gautelis.durga.generated.probes.%starterClass%Starter "$BOOTSTRAP" valid=true
>>

demoScenarioScript(processId, starterClass, firstTask, lastTask) ::= <<
#!/usr/bin/env bash
set -euo pipefail

BOOTSTRAP=${BOOTSTRAP:-localhost:9094}
SCENARIO=${1:-happy}

case "$SCENARIO" in
  happy|stuck|failed) ;;
  *)
    echo "Usage: $0 [happy|stuck|failed]"
    exit 1
    ;;
esac

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${ROOT_DIR}"

mvn -q clean package

JAR="target/%processId%-generated-1.0-SNAPSHOT-all.jar"
if [[ ! -f "$JAR" ]]; then
  echo "Missing shaded jar at $JAR"
  exit 1
fi

instance_id="$(uuidgen | tr '[:upper:]' '[:lower:]')"
java -cp "$JAR" org.gautelis.durga.generated.probes.%starterClass%Runner "$BOOTSTRAP" "$SCENARIO" "$instance_id"
>>

