andJoinGatewayClass(packageName, className, processId, outputChannel, outputTaskId, incomingMethodsBlock, joinCondition) ::= <<
package %packageName%;

import jakarta.annotation.PreDestroy;
import jakarta.enterprise.context.ApplicationScoped;
import jakarta.inject.Inject;
import org.eclipse.microprofile.reactive.messaging.Channel;
import org.eclipse.microprofile.reactive.messaging.Incoming;
import org.eclipse.microprofile.reactive.messaging.Message;
import io.smallrye.reactive.messaging.MutinyEmitter;
import org.gautelis.durga.ProcessEvent;
import org.gautelis.durga.ProcessState;
import org.gautelis.durga.ProcessStateStore;
import org.gautelis.durga.ScopeCancellationRegistry;

import java.time.Duration;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.concurrent.CompletionStage;
import java.util.UUID;

@ApplicationScoped
public class %className% {
    private final ProcessStateStore stateStore =
            new ProcessStateStore("localhost:9094", "%processId%_state", "%processId%");

    @Inject
    ScopeCancellationRegistry cancellationRegistry;

    @Inject
    @Channel("process-events")
    MutinyEmitter<String> processEventsEmitter;

    @Inject
    @Channel("%outputChannel%")
    MutinyEmitter<String> outputEmitter;

%incomingMethodsBlock%

    private CompletionStage<Void> handleJoin(String activityId, Message<String> msg) {
        ProcessEvent event = ProcessEvent.fromJson(msg.getPayload());
        if (event.status() != ProcessEvent.Status.COMPLETED) {
            return msg.ack();
        }
        if (cancellationRegistry.isCancelled(event.processInstanceId(), "%outputTaskId%")) {
            return msg.ack();
        }

        ProcessState state = stateStore.loadLatest(event.processInstanceId(), Duration.ofSeconds(2));
        List<ProcessState.Token> tokens = new ArrayList<>();
        Map<String, Object> variables = new HashMap<>();
        long version = 0;
        if (state != null) {
            if (state.tokens() != null) {
                tokens.addAll(state.tokens());
            }
            if (state.variables() != null) {
                variables.putAll(state.variables());
            }
            version = state.version();
        }

        tokens.add(new ProcessState.Token(UUID.randomUUID().toString(), activityId));
        stateStore.save(new ProcessState(event.processInstanceId(), tokens, variables, version + 1));

        boolean ready = %joinCondition%;
        if (ready) {
            ProcessEvent nextEvent = new ProcessEvent(
                    event.processInstanceId(),
                    event.processId(),
                    "%outputTaskId%",
                    UUID.randomUUID().toString(),
                    event.correlationId(),
                    event.payload(),
                    ProcessEvent.Status.STARTED,
                    null,
                    ProcessEvent.EventType.ACTIVITY_ENTERED,
                    event.processVersion(),
                    event.businessKey(),
                    null
            );
            outputEmitter.send(nextEvent.toJson());
            processEventsEmitter.send(new ProcessEvent(
                    nextEvent.processInstanceId(),
                    nextEvent.processId(),
                    nextEvent.activityId(),
                    nextEvent.tokenId(),
                    nextEvent.correlationId(),
                    nextEvent.payload(),
                    nextEvent.status(),
                    nextEvent.error(),
                    ProcessEvent.EventType.GATEWAY_TAKEN,
                    nextEvent.processVersion(),
                    nextEvent.businessKey(),
                    nextEvent.timestamp()
            ).toJson());
        }
        return msg.ack();
    }

    @PreDestroy
    public void close() {
        stateStore.close();
    }
}
>>

sendTaskClass(packageName, className, processId, taskId, taskType) ::= <<
package %packageName%;

import jakarta.enterprise.context.ApplicationScoped;
import jakarta.inject.Inject;
import org.eclipse.microprofile.reactive.messaging.Channel;
import org.eclipse.microprofile.reactive.messaging.Emitter;
import org.eclipse.microprofile.reactive.messaging.Incoming;
import org.eclipse.microprofile.reactive.messaging.Message;
import org.gautelis.durga.ProcessEvent;
import org.gautelis.durga.ScopeCancellationRegistry;

import java.util.HashMap;
import java.util.Map;
import java.util.concurrent.CompletionStage;

@ApplicationScoped
public class %className% {
    @Inject
    @Channel("process-events")
    Emitter<String> processEventsEmitter;

    @Inject
    @Channel("%processId%_%taskId%_output")
    Emitter<String> outputEmitter;

    @Inject
    @Channel("%processId%_%taskId%_send")
    Emitter<String> sendEmitter;

    @Inject
    ScopeCancellationRegistry cancellationRegistry;

    @Incoming("%processId%_%taskId%_input")
    public CompletionStage<Void> handle(Message<String> msg) {
        ProcessEvent inputEvent = ProcessEvent.fromJson(msg.getPayload());
        if (cancellationRegistry.isCancelled(inputEvent.processInstanceId(), "%taskId%")) {
            return msg.ack();
        }
        Map<String, Object> outputPayload = new HashMap<>();
        if (inputEvent.payload() != null) {
            outputPayload.putAll(inputEvent.payload());
        }
        outputPayload.put("sender", "%taskId%");
        outputPayload.put("taskType", "%taskType%");

        ProcessEvent outputEvent = new ProcessEvent(
                inputEvent.processInstanceId(),
                inputEvent.processId(),
                "%taskId%",
                inputEvent.tokenId(),
                inputEvent.correlationId(),
                outputPayload,
                ProcessEvent.Status.COMPLETED,
                null,
                ProcessEvent.EventType.ACTIVITY_COMPLETED,
                inputEvent.processVersion(),
                inputEvent.businessKey(),
                null
        );

        sendEmitter.send(outputEvent.toJson());
        outputEmitter.send(outputEvent.toJson());
        processEventsEmitter.send(outputEvent.toJson());
        return msg.ack();
    }
}
