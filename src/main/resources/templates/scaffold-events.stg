        ProcessEvent event = ProcessEvent.fromJson(msg.getPayload());
        if ("%signalId%".equals(event.activityId())
                && event.eventType() == ProcessEvent.EventType.ACTIVITY_CANCELLED) {
            waitingInstances.remove(event.processInstanceId());
        }
        return msg.ack();
    }

    @Incoming("%inputChannel%")
    public CompletionStage<Void> enterWaitState(Message<String> msg) {
        ProcessEvent inputEvent = ProcessEvent.fromJson(msg.getPayload());
        if (cancellationRegistry.isCancelled(inputEvent.processInstanceId(), "%signalId%")) {
            return msg.ack();
        }
        waitingInstances.put(inputEvent.processInstanceId(), inputEvent);

        processEventsEmitter.send(new ProcessEvent(
                inputEvent.processInstanceId(),
                inputEvent.processId(),
                "%signalId%",
                inputEvent.tokenId(),
                inputEvent.correlationId(),
                inputEvent.payload(),
                ProcessEvent.Status.STARTED,
                null,
                ProcessEvent.EventType.ACTIVITY_ENTERED,
                inputEvent.processVersion(),
                inputEvent.businessKey(),
                null
        ).toJson());
        return msg.ack();
    }

    @Incoming("%signalTopic%")
    public CompletionStage<Void> onSignal(Message<String> msg) {
        ProcessEvent signalEvent = ProcessEvent.fromJson(msg.getPayload());
        ProcessEvent waiting = waitingInstances.remove(signalEvent.processInstanceId());
        if (waiting == null) {
            return msg.ack();
        }
        if (cancellationRegistry.isCancelled(waiting.processInstanceId(), "%signalId%")) {
            return msg.ack();
        }

        processEventsEmitter.send(new ProcessEvent(
                waiting.processInstanceId(),
                waiting.processId(),
                "%signalId%",
                waiting.tokenId(),
                waiting.correlationId(),
                signalEvent.payload(),
                ProcessEvent.Status.COMPLETED,
                null,
                ProcessEvent.EventType.ACTIVITY_COMPLETED,
                waiting.processVersion(),
                waiting.businessKey(),
                null
        ).toJson());

        if ("%outputNodeType%".equals("endEvent")) {
            processEventsEmitter.send(new ProcessEvent(
                    waiting.processInstanceId(),
                    waiting.processId(),
                    "%outputActivityId%",
                    waiting.tokenId(),
                    waiting.correlationId(),
                    signalEvent.payload(),
                    ProcessEvent.Status.COMPLETED,
                    null,
                    ProcessEvent.EventType.PROCESS_COMPLETED,
                    waiting.processVersion(),
                    waiting.businessKey(),
                    null
            ).toJson());
            return msg.ack();
        }

        ProcessEvent nextEvent = new ProcessEvent(
                waiting.processInstanceId(),
                waiting.processId(),
                "%outputActivityId%",
                waiting.tokenId(),
                waiting.correlationId(),
                signalEvent.payload(),
                ProcessEvent.Status.STARTED,
                null,
                ProcessEvent.EventType.ACTIVITY_ENTERED,
                waiting.processVersion(),
                waiting.businessKey(),
                null
        );
        return java.util.concurrent.CompletableFuture.allOf(
                outputEmitter.send(nextEvent.toJson()).toCompletableFuture(),
                processEventsEmitter.send(nextEvent.toJson()).toCompletableFuture()
        ).thenCompose(ignored -> msg.ack());
    }
}
>>

signalThrowEventClass(packageName, className, inputChannel, signalTopic, signalId, signalName, outputChannel, outputActivityId, outputNodeType) ::= <<
package %packageName%;

import jakarta.enterprise.context.ApplicationScoped;
import jakarta.inject.Inject;
import org.eclipse.microprofile.reactive.messaging.Channel;
import org.eclipse.microprofile.reactive.messaging.Emitter;
import org.eclipse.microprofile.reactive.messaging.Incoming;
import org.gautelis.durga.ProcessEvent;
import org.gautelis.durga.ScopeCancellationRegistry;

@ApplicationScoped
public class %className% {
    @Inject
    ScopeCancellationRegistry cancellationRegistry;

    @Inject
    @Channel("process-events")
    Emitter<String> processEventsEmitter;

    @Inject
    @Channel("%signalTopic%")
    Emitter<String> signalEmitter;

    @Inject
    @Channel("%outputChannel%")
    Emitter<String> outputEmitter;

    @Incoming("%inputChannel%")
    public void throwSignal(String payload) {
        ProcessEvent inputEvent = ProcessEvent.fromJson(payload);
        if (cancellationRegistry.isCancelled(inputEvent.processInstanceId(), "%signalId%")) {
            return;
        }
        ProcessEvent thrownSignal = new ProcessEvent(
                inputEvent.processInstanceId(),
                inputEvent.processId(),
                "%signalId%",
                inputEvent.tokenId(),
                inputEvent.correlationId(),
                inputEvent.payload(),
                ProcessEvent.Status.COMPLETED,
                null,
                ProcessEvent.EventType.ACTIVITY_COMPLETED,
                inputEvent.processVersion(),
                inputEvent.businessKey(),
                null
        );
        signalEmitter.send(thrownSignal.toJson());
        processEventsEmitter.send(thrownSignal.toJson());

        if ("%outputNodeType%".equals("endEvent")) {
            processEventsEmitter.send(new ProcessEvent(
                    inputEvent.processInstanceId(),
                    inputEvent.processId(),
                    "%outputActivityId%",
                    inputEvent.tokenId(),
                    inputEvent.correlationId(),
                    inputEvent.payload(),
                    ProcessEvent.Status.COMPLETED,
                    null,
                    ProcessEvent.EventType.PROCESS_COMPLETED,
                    inputEvent.processVersion(),
                    inputEvent.businessKey(),
                    null
            ).toJson());
            return;
        }

        ProcessEvent nextEvent = new ProcessEvent(
                inputEvent.processInstanceId(),
                inputEvent.processId(),
                "%outputActivityId%",
                inputEvent.tokenId(),
                inputEvent.correlationId(),
                inputEvent.payload(),
                ProcessEvent.Status.STARTED,
                null,
                ProcessEvent.EventType.ACTIVITY_ENTERED,
                inputEvent.processVersion(),
                inputEvent.businessKey(),
                null
        );
        outputEmitter.send(nextEvent.toJson());
        processEventsEmitter.send(nextEvent.toJson());
    }
}
>>

callActivityHandlerClass(packageName, className, processId, taskId, calledElement, inputChannel, requestChannel, replyChannel, outputChannel, nextChannel, nextActivityId, nextNodeType) ::= <<
package %packageName%;

import jakarta.enterprise.context.ApplicationScoped;
import jakarta.inject.Inject;
import org.eclipse.microprofile.reactive.messaging.Channel;
import org.eclipse.microprofile.reactive.messaging.Emitter;
import org.eclipse.microprofile.reactive.messaging.Incoming;
import org.eclipse.microprofile.reactive.messaging.Message;
import org.gautelis.durga.ProcessEvent;
import org.gautelis.durga.ScopeCancellationRegistry;

import java.time.Instant;
import java.util.HashMap;
import java.util.Map;
import java.util.concurrent.CompletionStage;
import java.util.concurrent.ConcurrentHashMap;

@ApplicationScoped
public class %className% {
    private final Map<String, ProcessEvent> waitingInstances = new ConcurrentHashMap<String, ProcessEvent>();

    @Inject
    ScopeCancellationRegistry cancellationRegistry;

    @Inject
    @Channel("process-events")
    Emitter<String> processEventsEmitter;

    @Inject
    @Channel("%requestChannel%")
    Emitter<String> requestEmitter;

    @Inject
    @Channel("%outputChannel%")
    Emitter<String> outputEmitter;

    @Inject
    @Channel("%nextChannel%")
    Emitter<String> nextEmitter;

    @Incoming("process-events-monitor")
    public CompletionStage<Void> onProcessEvent(Message<String> msg) {
        ProcessEvent event = ProcessEvent.fromJson(msg.getPayload());
        if ("%taskId%".equals(event.activityId())
                && event.eventType() == ProcessEvent.EventType.ACTIVITY_CANCELLED) {
            waitingInstances.remove(event.processInstanceId());
        }
        return msg.ack();
    }

    @Incoming("%inputChannel%")
    public CompletionStage<Void> invoke(Message<String> msg) {
        ProcessEvent inputEvent = ProcessEvent.fromJson(msg.getPayload());
        if (cancellationRegistry.isCancelled(inputEvent.processInstanceId(), "%taskId%")) {
            return msg.ack();
        }
        waitingInstances.put(inputEvent.processInstanceId(), inputEvent);

        Map<String, Object> requestPayload = new HashMap<String, Object>();
        if (inputEvent.payload() != null) {
            requestPayload.putAll(inputEvent.payload());
        }
        requestPayload.put("callActivityId", "%taskId%");
        requestPayload.put("calledElement", "%calledElement%");
        requestPayload.put("waitingForReply", true);

        ProcessEvent entered = new ProcessEvent(
                inputEvent.processInstanceId(),
                inputEvent.processId(),
                "%taskId%",
                inputEvent.tokenId(),
                inputEvent.correlationId(),
                requestPayload,
                ProcessEvent.Status.STARTED,
                null,
                ProcessEvent.EventType.ACTIVITY_ENTERED,
                inputEvent.processVersion(),
                inputEvent.businessKey(),
                Instant.now().toString()
        );
        return java.util.concurrent.CompletableFuture.allOf(
                processEventsEmitter.send(entered.toJson()).toCompletableFuture(),
                requestEmitter.send(entered.toJson()).toCompletableFuture()
        ).thenCompose(ignored -> msg.ack());
    }

    @Incoming("%replyChannel%")
    public CompletionStage<Void> onReply(Message<String> msg) {
        ProcessEvent replyEvent = ProcessEvent.fromJson(msg.getPayload());
        ProcessEvent waiting = waitingInstances.remove(replyEvent.processInstanceId());
        if (waiting == null) {
            return msg.ack();
        }
        if (cancellationRegistry.isCancelled(waiting.processInstanceId(), "%taskId%")) {
            return msg.ack();
        }

        Map<String, Object> completionPayload = new HashMap<String, Object>();
        if (waiting.payload() != null) {
            completionPayload.putAll(waiting.payload());
        }
        if (replyEvent.payload() != null) {
            completionPayload.putAll(replyEvent.payload());
        }
        completionPayload.put("callActivityId", "%taskId%");
        completionPayload.put("calledElement", "%calledElement%");
        completionPayload.put("waitingForReply", false);

        ProcessEvent completed = new ProcessEvent(
                waiting.processInstanceId(),
                waiting.processId(),
                "%taskId%",
                waiting.tokenId(),
                waiting.correlationId(),
                completionPayload,
                ProcessEvent.Status.COMPLETED,
                replyEvent.error(),
                ProcessEvent.EventType.ACTIVITY_COMPLETED,
                waiting.processVersion(),
                waiting.businessKey(),
                Instant.now().toString()
        );
        outputEmitter.send(completed.toJson());
        processEventsEmitter.send(completed.toJson());

        if ("%nextNodeType%".equals("endEvent")) {
            processEventsEmitter.send(new ProcessEvent(
                    waiting.processInstanceId(),
                    waiting.processId(),
                    "%nextActivityId%",
                    waiting.tokenId(),
                    waiting.correlationId(),
                    completionPayload,
                    ProcessEvent.Status.COMPLETED,
                    replyEvent.error(),
                    ProcessEvent.EventType.PROCESS_COMPLETED,
                    waiting.processVersion(),
                    waiting.businessKey(),
                    Instant.now().toString()
            ).toJson());
            return msg.ack();
        }

        ProcessEvent nextEvent = new ProcessEvent(
                waiting.processInstanceId(),
                waiting.processId(),
                "%nextActivityId%",
                waiting.tokenId(),
                waiting.correlationId(),
                completionPayload,
                ProcessEvent.Status.STARTED,
                replyEvent.error(),
                ProcessEvent.EventType.ACTIVITY_ENTERED,
                waiting.processVersion(),
                waiting.businessKey(),
                Instant.now().toString()
        );
        return java.util.concurrent.CompletableFuture.allOf(
                nextEmitter.send(nextEvent.toJson()).toCompletableFuture(),
                processEventsEmitter.send(nextEvent.toJson()).toCompletableFuture()
        ).thenCompose(ignored -> msg.ack());
    }
}
>>
