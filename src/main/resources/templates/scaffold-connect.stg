connectSourceConfig(processId, sourceTopics) ::= <<
{
  "name": "%processId%-source",
  "config": {
    "connector.class": "<fill in connector class>",
    "tasks.max": "1",
    "topics": "%sourceTopics%"
  },
  "_comment": "Fill in connector.class and provider-specific config (connection.url, table.whitelist, etc.). The topics field lists the Kafka topics this source writes to."
}
>>

connectSinkConfig(processId, sinkTopics) ::= <<
{
  "name": "%processId%-sink",
  "config": {
    "connector.class": "<fill in connector class>",
    "tasks.max": "1",
    "topics": "%sinkTopics%"
  },
  "_comment": "Fill in connector.class and provider-specific config (connection.url, s3.bucket.name, etc.). The topics field lists the Kafka topics this sink reads from."
}
>>

dataStoreConnectConfig(spec) ::= <<
{
  "name": "%spec.name%",
  "config": {
    "connector.class": "%spec.connectorClass%",
    "tasks.max": "1",
    "topics": "%spec.topics%",
    "durga.data.store": "%spec.storeName%",
    "durga.data.store.kind": "%spec.kind%",
    "durga.data.store.uri": "%spec.uri%"
  },
  "_comment": "%spec.comment%"
}
>>

connectScript(processId) ::= <<
#!/usr/bin/env bash
set -euo pipefail
CONNECT_URL=${CONNECT_URL:-http://localhost:8083}

shopt -s nullglob

for config in connect/*.json connect/data-stores/*.json; do
  name=$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["name"])' "$config")
  echo "===> Posting connector ${name} from ${config}"
  HTTP_CODE=$(curl -s -o /dev/null -w "\%{http_code}" -X POST \
    -H "Content-Type: application/json" \
    -d @"$config" \
    "${CONNECT_URL}/connectors" || true)
  if [ "$HTTP_CODE" = "201" ]; then
    echo "  Created"
  elif [ "$HTTP_CODE" = "409" ]; then
    echo "  Already exists (HTTP 409)"
  else
    echo "  Unexpected response: HTTP ${HTTP_CODE}"
  fi

  echo "===> Connector status: ${name}"
  curl -s "${CONNECT_URL}/connectors/${name}/status" | python3 -m json.tool 2>/dev/null || true
  echo ""
done
>>

kedaScalers(processId, tasks) ::= <<
%tasks:{t|
apiVersion: keda.sh/v1alpha1
kind: ScaledObject
metadata:
  name: %processId%-%t%
  labels:
    app: %processId%
    task: %t%
spec:
  scaleTargetRef:
    name: %processId%-%t%
  minReplicaCount: 1
  maxReplicaCount: 10
  triggers:
    - type: kafka
      metadata:
        bootstrapServers: kafka-broker:9092
        consumerGroup: %processId%_%t%_worker
        topic: %processId%_%t%_input
        lagThreshold: "100"
    - type: prometheus
      metadata:
        serverAddress: http://durga-monitoring:8081
        metricName: durga_activity_latency_ms
        threshold: "30000"
        query: durga_activity_latency_ms{pct="p95",process_id="%processId%",activity_id="%t%"\}
---
}%>>

topicsYml(processId, tasks, timers, messageTopics, callActivities, subProcesses, retentionMs) ::= <<
%tasks:{t|
apiVersion: kafka.strimzi.io/v1beta2
kind: KafkaTopic
metadata:
  name: %processId%_%t%_input
  labels:
    strimzi.io/cluster: my-kafka
    app: %processId%
spec:
  partitions: 3
  replicas: 1
  config:
    retention.ms: "%retentionMs%"
---
apiVersion: kafka.strimzi.io/v1beta2
kind: KafkaTopic
metadata:
