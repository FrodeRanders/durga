<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://example.com/bpmn">
  <process id="invoice_subprocess_reminder_non_interrupting" name="Invoice Subprocess Reminder Non Interrupting" isExecutable="true">
    <startEvent id="start" name="Invoice Received"/>
    <sequenceFlow id="flow_start_to_register" sourceRef="start" targetRef="register_invoice"/>

    <serviceTask id="register_invoice" name="Register Invoice"/>
    <sequenceFlow id="flow_register_to_review_scope" sourceRef="register_invoice" targetRef="review_scope"/>

    <subProcess id="review_scope" name="Review Scope">
      <startEvent id="review_scope_start" name="Enter Review"/>
      <sequenceFlow id="flow_scope_start_to_review" sourceRef="review_scope_start" targetRef="review_invoice"/>

      <userTask id="review_invoice" name="Review Invoice"/>
      <sequenceFlow id="flow_review_to_approve" sourceRef="review_invoice" targetRef="approve_invoice"/>

      <serviceTask id="approve_invoice" name="Approve Invoice"/>
      <sequenceFlow id="flow_approve_to_scope_end" sourceRef="approve_invoice" targetRef="review_scope_end"/>

      <endEvent id="review_scope_end" name="Review Done"/>
    </subProcess>

    <boundaryEvent id="review_scope_reminder" name="Review Scope Reminder" attachedToRef="review_scope" cancelActivity="false">
      <timerEventDefinition>
        <timeDuration>PT15S</timeDuration>
      </timerEventDefinition>
    </boundaryEvent>
    <sequenceFlow id="flow_reminder_to_notify_manager" sourceRef="review_scope_reminder" targetRef="notify_manager"/>

    <sequenceFlow id="flow_scope_to_notify_requester" sourceRef="review_scope" targetRef="notify_requester"/>

    <serviceTask id="notify_manager" name="Notify Manager"/>
    <sequenceFlow id="flow_notify_manager_to_end" sourceRef="notify_manager" targetRef="end_reminder_sent"/>

    <serviceTask id="notify_requester" name="Notify Requester"/>
    <sequenceFlow id="flow_notify_requester_to_end" sourceRef="notify_requester" targetRef="end_completed"/>

    <endEvent id="end_completed" name="Invoice Reviewed"/>
    <endEvent id="end_reminder_sent" name="Reminder Sent"/>
  </process>
</definitions>
