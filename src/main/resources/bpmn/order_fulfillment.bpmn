<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://example.com/bpmn">
  <process id="order_fulfillment" name="Order Fulfillment" isExecutable="true">
    <startEvent id="start" name="Order Received"/>
    <sequenceFlow id="flow_start_to_validate" sourceRef="start" targetRef="validate_order"/>

    <serviceTask id="validate_order" name="Validate Order"/>
    <sequenceFlow id="flow_validate_to_gateway" sourceRef="validate_order" targetRef="order_valid"/>

    <exclusiveGateway id="order_valid" name="Order Valid?"/>
    <sequenceFlow id="flow_valid_to_fulfill" sourceRef="order_valid" targetRef="fulfill_order">
      <conditionExpression xsi:type="tFormalExpression">${valid == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_invalid_to_reject" sourceRef="order_valid" targetRef="reject_order">
      <conditionExpression xsi:type="tFormalExpression">${valid == false}</conditionExpression>
    </sequenceFlow>

    <serviceTask id="fulfill_order" name="Fulfill Order"/>
    <sequenceFlow id="flow_fulfill_to_ship" sourceRef="fulfill_order" targetRef="ship_order"/>

    <serviceTask id="ship_order" name="Ship Order"/>
    <sequenceFlow id="flow_ship_to_end" sourceRef="ship_order" targetRef="end_fulfilled"/>

    <serviceTask id="reject_order" name="Reject Order"/>
    <sequenceFlow id="flow_reject_to_end" sourceRef="reject_order" targetRef="end_rejected"/>

    <endEvent id="end_fulfilled" name="Order Fulfilled"/>
    <endEvent id="end_rejected" name="Order Rejected"/>
  </process>
</definitions>
